{
  "Alarms": [
    {
      "AlarmName": "paybridge-root-login-detected",
      "Description": "Alert when AWS root account is used — CC6.1",
      "MetricName": "RootAccountUsage",
      "Namespace": "CloudTrailMetrics",
      "Statistic": "Sum",
      "Period": 300,
      "EvaluationPeriods": 1,
      "Threshold": 1,
      "ComparisonOperator": "GreaterThanOrEqualToThreshold",
      "TreatMissingData": "notBreaching",
      "SOC2Control": "CC6.1"
    },
    {
      "AlarmName": "paybridge-iam-policy-change",
      "Description": "Alert on IAM policy changes — CC6.1",
